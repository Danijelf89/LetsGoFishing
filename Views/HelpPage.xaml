<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LetsGoFishing.ViewModels"
             xmlns:controls="clr-namespace:LetsGoFishing.Views.Controls"
             x:Class="LetsGoFishing.Views.HelpPage"
             x:DataType="vm:HelpViewModel"
             Title="Uputstvo"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource PageBackgroundDark}}">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="16" Spacing="16">
                <!-- Header -->
                <Label Text="Uputstvo za korišćenje"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                <Label Text="Dobrodošli u Let's Go Fishing - vašeg saveznika za uspešan ribolov!"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                       FontSize="14" />

                <!-- Kalendar Section -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12"
                        Padding="16">
                    <VerticalStackLayout Spacing="12">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="📅" FontSize="20" />
                            <Label Text="Kalendar"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <Label Text="Glavna stranica aplikacije koja prikazuje kalendar sa vremenskom prognozom za izabrani grad."
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                               FontSize="13" />

                        <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource DividerLight}, Dark={StaticResource DividerDark}}" />

                        <Label Text="Kako koristiti:"
                               TextColor="#1B5E20"
                               FontAttributes="Bold"
                               FontSize="14" />

                        <VerticalStackLayout Spacing="8">
                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="• " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Dodirnite bilo koji dan " FontAttributes="Bold" />
                                        <Span Text="u kalendaru da otvorite meni sa opcijama" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="• " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Meni nudi opcije:" FontAttributes="Bold" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <VerticalStackLayout Padding="20,0,0,0" Spacing="4">
                                <Label Text="- Vidi ribe za ovaj dan: Lista vrsta i njihov status" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" FontSize="12" />
                                <Label Text="- Vidi vremensku prognozu: Detaljna prognoza za dan" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" FontSize="12" />
                                <Label Text="- Dodaj zapis u dnevnik: Unesi pecanje za taj dan" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" FontSize="12" />
                            </VerticalStackLayout>

                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="• " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Dugme 🔄 " FontAttributes="Bold" />
                                        <Span Text="(gore levo) osvežava vremensku prognozu" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="• " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Prognoza " FontAttributes="Bold" />
                                        <Span Text="se učitava automatski kada izaberete grad" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Lovostaj Section -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12"
                        Padding="16">
                    <VerticalStackLayout Spacing="12">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="🐟" FontSize="20" />
                            <Label Text="Lovostaj"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <Label Text="Stranica sa listom svih vrsta riba i njihovim periodima lovostaja."
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                               FontSize="13" />

                        <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource DividerLight}, Dark={StaticResource DividerDark}}" />

                        <Label Text="Šta možete videti:"
                               TextColor="#1B5E20"
                               FontAttributes="Bold"
                               FontSize="14" />

                        <VerticalStackLayout Spacing="8">
                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="• " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Lista svih vrsta riba " FontAttributes="Bold" />
                                        <Span Text="sa informacijama o lovostaju" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="• " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Ribe u lovostaju " FontAttributes="Bold" />
                                        <Span Text="su prikazane na vrhu liste sa crvenom oznakom" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="• " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Aktivne ribe " FontAttributes="Bold" />
                                        <Span Text="su označene zelenom bojom" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="• " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Datumi lovostaja " FontAttributes="Bold" />
                                        <Span Text="su prikazani ispod imena svake vrste" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="• " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Pretraga " FontAttributes="Bold" />
                                        <Span Text="omogućava brzo pronalaženje željene vrste" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Dnevnik Section -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12"
                        Padding="16">
                    <VerticalStackLayout Spacing="12">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="📓" FontSize="20" />
                            <Label Text="Dnevnik"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <Label Text="Vaš lični dnevnik pecanja gde beležite sve ulove i izlaske."
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                               FontSize="13" />

                        <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource DividerLight}, Dark={StaticResource DividerDark}}" />

                        <Label Text="Kako dodati unos:"
                               TextColor="#1B5E20"
                               FontAttributes="Bold"
                               FontSize="14" />

                        <VerticalStackLayout Spacing="8">
                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="1. " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Na kalendaru dodirnite " />
                                        <Span Text="željeni dan " FontAttributes="Bold" />
                                        <Span Text="da otvorite meni" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="2. " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Izaberite opciju " />
                                        <Span Text="'Dodaj zapis u dnevnik'" FontAttributes="Bold" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="3. " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Unesite detalje o pecanju (naslov, ulov, beleške)" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="4. " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Sačuvajte unos - automatski će se pojaviti u dnevniku" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource DividerLight}, Dark={StaticResource DividerDark}}" />

                        <Label Text="Na stranici Dnevnik možete:"
                               TextColor="#1B5E20"
                               FontAttributes="Bold"
                               FontSize="14" />

                        <VerticalStackLayout Spacing="8">
                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="• " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Videti sve zapise " FontAttributes="Bold" />
                                        <Span Text="sortirane po datumu" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="• " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Izmeniti " FontAttributes="Bold" />
                                        <Span Text="postojeći zapis klikom na olovku" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="• " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Obrisati " FontAttributes="Bold" />
                                        <Span Text="zapis klikom na kantu za smeće" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="• " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Dodati novi zapis " FontAttributes="Bold" />
                                        <Span Text="klikom na '+ Novi zapis'" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Lokacija Section -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12"
                        Padding="16">
                    <VerticalStackLayout Spacing="12">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="📍" FontSize="20" />
                            <Label Text="Lokacija pecanja"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <Label Text="Sačuvajte GPS lokaciju omiljenih ribolovnih mesta da ih lako pronađete ponovo."
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                               FontSize="13" />

                        <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource DividerLight}, Dark={StaticResource DividerDark}}" />

                        <Label Text="Kako sačuvati lokaciju:"
                               TextColor="#1B5E20"
                               FontAttributes="Bold"
                               FontSize="14" />

                        <VerticalStackLayout Spacing="8">
                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="1. " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Kada kreirate ili menjate zapis u dnevniku" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="2. " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Pritisnite dugme " />
                                        <Span Text="📍 " FontAttributes="Bold" />
                                        <Span Text="u sekciji Lokacija" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="3. " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Dozvolite pristup lokaciji kada vas telefon pita" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="4. " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="GPS koordinate će se automatski sačuvati" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource DividerLight}, Dark={StaticResource DividerDark}}" />

                        <Label Text="Kako pronaći sačuvanu lokaciju:"
                               TextColor="#1B5E20"
                               FontAttributes="Bold"
                               FontSize="14" />

                        <VerticalStackLayout Spacing="8">
                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="• " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Na stranici Dnevnik " FontAttributes="Bold" />
                                        <Span Text="zapisi sa lokacijom imaju oznaku 📍" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="• " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Pritisnite dugme 🎯 " FontAttributes="Bold" />
                                        <Span Text="da otvorite Google Maps na toj lokaciji" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="• " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Koristite navigaciju " FontAttributes="Bold" />
                                        <Span Text="u Google Maps da stignete do mesta" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Podešavanja Section -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12"
                        Padding="16">
                    <VerticalStackLayout Spacing="12">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="⚙️" FontSize="20" />
                            <Label Text="Podešavanja"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <Label Text="Prilagodite aplikaciju vašim potrebama."
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                               FontSize="13" />

                        <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource DividerLight}, Dark={StaticResource DividerDark}}" />

                        <Label Text="Dostupne opcije:"
                               TextColor="#1B5E20"
                               FontAttributes="Bold"
                               FontSize="14" />

                        <VerticalStackLayout Spacing="8">
                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="• " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Izbor grada " FontAttributes="Bold" />
                                        <Span Text="- izaberite grad za vremensku prognozu" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="• " FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Span Text="Tamna/Svetla tema " FontAttributes="Bold" />
                                        <Span Text="- prilagodite izgled aplikacije" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Data Storage Section -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12"
                        Padding="16">
                    <VerticalStackLayout Spacing="12">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="💾" FontSize="20" />
                            <Label Text="Čuvanje podataka"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <Label Text="Informacije o tome gde se čuvaju vaši podaci."
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                               FontSize="13" />

                        <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource DividerLight}, Dark={StaticResource DividerDark}}" />

                        <VerticalStackLayout Spacing="8">
                            <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Svi vaši zapisi iz dnevnika i podešavanja se čuvaju lokalno na vašem telefonu." />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label Text="Lokacija podataka:"
                                   TextColor="#1B5E20"
                                   FontAttributes="Bold"
                                   FontSize="14"
                                   Margin="0,8,0,0" />

                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardSecondaryLight}, Dark={StaticResource CardSecondaryDark}}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="12">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding DataLocation}"
                                           TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"
                                           FontSize="11"
                                           FontFamily="Consolas" />
                                </VerticalStackLayout>
                            </Border>

                            <Label Text="Fajlovi koji se čuvaju:"
                                   TextColor="#1B5E20"
                                   FontAttributes="Bold"
                                   FontSize="14"
                                   Margin="0,8,0,0" />

                            <VerticalStackLayout Spacing="4" Padding="8,0,0,0">
                                <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="12">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="• diary.json " FontAttributes="Bold" TextColor="#4CAF50" />
                                            <Span Text="- vaši zapisi iz dnevnika" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <Label TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="12">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="• settings.json " FontAttributes="Bold" TextColor="#4CAF50" />
                                            <Span Text="- vaša podešavanja (grad, tema)" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </VerticalStackLayout>

                            <Label Text="Napomena: Podaci se čuvaju samo na vašem uređaju i nisu dostupni drugim aplikacijama."
                                   TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"
                                   FontSize="11"
                                   FontAttributes="Italic"
                                   Margin="0,8,0,0" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Footer spacing -->
                <BoxView HeightRequest="16" BackgroundColor="Transparent" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- Fish Footer -->
        <controls:FishFooter Grid.Row="1" />
    </Grid>
</ContentPage>
