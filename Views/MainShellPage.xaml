<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LetsGoFishing.Views.MainShellPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#121212">

    <Grid RowDefinitions="*,Auto">
        <!-- Content area with tabs -->
        <Grid x:Name="ContentArea">
            <!-- Tab content will be managed in code-behind -->
        </Grid>

        <!-- Fish footer animation -->
        <Border Grid.Row="1" HeightRequest="50">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#E3F2FD" Offset="0" />
                    <GradientStop Color="#90CAF9" Offset="0.3" />
                    <GradientStop Color="#42A5F5" Offset="0.7" />
                    <GradientStop Color="#1E88E5" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Label x:Name="Fish1" Text="🐟" FontSize="24" VerticalOptions="Center" />
                <Label x:Name="Fish2" Text="🐟" FontSize="18" VerticalOptions="End" Margin="0,0,0,5" ScaleX="-1" />
                <Label x:Name="Fish3" Text="🐟" FontSize="14" VerticalOptions="Start" Margin="0,5,0,0" />
                <Label x:Name="Fish4" Text="🐋" FontSize="32" VerticalOptions="Center" Opacity="0.85" ScaleX="-1" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>
