<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LetsGoFishing.ViewModels"
             xmlns:models="clr-namespace:LetsGoFishing.Models"
             xmlns:controls="clr-namespace:LetsGoFishing.Views.Controls"
             x:Class="LetsGoFishing.Views.DiaryPage"
             x:DataType="vm:DiaryViewModel"
             Title="Dnevnik"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource PageBackgroundDark}}">

    <Grid RowDefinitions="*,Auto">
        <!-- Main content -->
        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="16">
                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout>
                        <Label Text="Dnevnik pecanja"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                        <!-- Year navigation -->
                        <HorizontalStackLayout Spacing="12" Margin="0,8,0,0">
                            <Button Text="◄"
                                    Command="{Binding ChangeYearCommand}"
                                    CommandParameter="-1"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource CardSecondaryLight}, Dark={StaticResource CardSecondaryDark}}"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                    WidthRequest="40"
                                    HeightRequest="36"
                                    CornerRadius="8" />
                            <Label Text="{Binding SelectedYear}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                   VerticalOptions="Center" />
                            <Button Text="►"
                                    Command="{Binding ChangeYearCommand}"
                                    CommandParameter="1"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource CardSecondaryLight}, Dark={StaticResource CardSecondaryDark}}"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                    WidthRequest="40"
                                    HeightRequest="36"
                                    CornerRadius="8" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <Button Grid.Column="1"
                            Text="+ Novi zapis"
                            Command="{Binding OpenNewEntryCommand}"
                            BackgroundColor="#1B5E20"
                            TextColor="White"
                            CornerRadius="8"
                            VerticalOptions="Start" />
                </Grid>

                <!-- Loading -->
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#1B5E20"
                                   HorizontalOptions="Center" />

                <!-- Entries list -->
                <CollectionView ItemsSource="{Binding Entries}"
                                SelectionMode="None"
                                IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Padding="40">
                            <Label Text="Nema zapisa za ovu godinu"
                                   TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"
                                   FontSize="16"
                                   HorizontalOptions="Center" />
                            <Label Text="Dodajte prvi zapis klikom na dugme 'Novi zapis'"
                                   TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"
                                   FontSize="13"
                                   HorizontalOptions="Center"
                                   Margin="0,8,0,0" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:DiaryEntryItem">
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="16"
                                    Margin="0,0,0,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DiaryViewModel}}, Path=ViewEntryCommand}"
                                                          CommandParameter="{Binding}" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding Title}"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                               VerticalOptions="Center" />
                                        <HorizontalStackLayout Grid.Column="1" Spacing="6">
                                            <Button Text="🎯"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DiaryViewModel}}, Path=OpenLocationInMapsCommand}"
                                                    CommandParameter="{Binding}"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource CardSecondaryLight}, Dark={StaticResource CardSecondaryDark}}"
                                                    WidthRequest="36"
                                                    HeightRequest="36"
                                                    CornerRadius="8"
                                                    Padding="0"
                                                    IsVisible="{Binding HasLocation}" />
                                            <Button Text="✏️"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DiaryViewModel}}, Path=EditEntryCommand}"
                                                    CommandParameter="{Binding}"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource CardSecondaryLight}, Dark={StaticResource CardSecondaryDark}}"
                                                    WidthRequest="36"
                                                    HeightRequest="36"
                                                    CornerRadius="8"
                                                    Padding="0" />
                                            <Button Text="🗑️"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DiaryViewModel}}, Path=DeleteEntryCommand}"
                                                    CommandParameter="{Binding}"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource CardSecondaryLight}, Dark={StaticResource CardSecondaryDark}}"
                                                    WidthRequest="36"
                                                    HeightRequest="36"
                                                    CornerRadius="8"
                                                    Padding="0" />
                                        </HorizontalStackLayout>
                                    </Grid>
                                    <HorizontalStackLayout Spacing="12">
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="📅" FontSize="11" />
                                            <Label Text="{Binding DateDisplay}" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" FontSize="12" />
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="🐟" FontSize="11" />
                                            <Label Text="{Binding FishSummary}" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" FontSize="12" />
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Spacing="4" IsVisible="{Binding HasLocation}">
                                            <Label Text="📍" FontSize="11" />
                                            <Label Text="Sačuvano" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" FontSize="12" />
                                        </HorizontalStackLayout>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Footer stats -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12"
                        Padding="16">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                        <Label Text="📅" FontSize="16" VerticalOptions="Center" />
                        <Label Text="Dana na vodi:" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" FontSize="14" VerticalOptions="Center" />
                        <Label Text="{Binding FishingDaysCount}"
                               TextColor="#1B5E20"
                               FontSize="20"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                        <Label Text="dana" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" FontSize="14" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Fish Footer -->
        <controls:FishFooter Grid.Row="1" />

        <!-- Editor/View overlay -->
        <Grid Grid.RowSpan="2" IsVisible="{Binding IsEditorOpen}" InputTransparent="False" BackgroundColor="#80000000">
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 16"
                    Margin="16"
                    MaximumWidthRequest="500"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                <ScrollView>
                    <VerticalStackLayout Padding="20" Spacing="16">
                        <!-- Header -->
                        <Grid ColumnDefinitions="*,Auto">
                            <!-- View Mode Header -->
                            <Label Text="Prikaz zapisa"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                   IsVisible="{Binding IsViewMode}" />
                            <!-- Edit Mode Header -->
                            <Label Text="{Binding IsEditMode, Converter={StaticResource BoolToEditModeTextConverter}}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                   IsVisible="{Binding IsViewMode, Converter={StaticResource InvertedBoolConverter}}" />
                            <Button Grid.Column="1"
                                    Text="✕"
                                    Command="{Binding CancelEditorCommand}"
                                    BackgroundColor="Transparent"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                    WidthRequest="40"
                                    HeightRequest="40" />
                        </Grid>

                        <!-- Title - View Mode -->
                        <VerticalStackLayout Spacing="4" IsVisible="{Binding IsViewMode}">
                            <Label Text="Naslov" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" FontSize="12" />
                            <Label Text="{Binding EditorTitle}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                        </VerticalStackLayout>

                        <!-- Title - Edit Mode -->
                        <VerticalStackLayout Spacing="4" IsVisible="{Binding IsViewMode, Converter={StaticResource InvertedBoolConverter}}">
                            <HorizontalStackLayout>
                                <Label Text="Naslov" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" FontAttributes="Bold" />
                                <Label Text=" *" TextColor="#F44336" />
                            </HorizontalStackLayout>
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardSecondaryLight}, Dark={StaticResource CardSecondaryDark}}" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="12">
                                <Entry Text="{Binding EditorTitle}"
                                       Placeholder="Unesite naslov zapisa..."
                                       PlaceholderColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                       BackgroundColor="Transparent" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Date - View Mode -->
                        <VerticalStackLayout Spacing="4" IsVisible="{Binding IsViewMode}">
                            <Label Text="Datum" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" FontSize="12" />
                            <Label Text="{Binding EditorDate, StringFormat='{0:d. MMMM yyyy.}'}"
                                   FontSize="16"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                        </VerticalStackLayout>

                        <!-- Date - Edit Mode -->
                        <VerticalStackLayout Spacing="4" IsVisible="{Binding IsViewMode, Converter={StaticResource InvertedBoolConverter}}">
                            <Label Text="Datum" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" FontAttributes="Bold" />
                            <DatePicker Date="{Binding EditorDate}"
                                        TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource CardSecondaryLight}, Dark={StaticResource CardSecondaryDark}}" />
                        </VerticalStackLayout>

                        <!-- Notes - View Mode -->
                        <VerticalStackLayout Spacing="4" IsVisible="{Binding IsViewMode}">
                            <Label Text="Beleške" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" FontSize="12" />
                            <Label Text="{Binding EditorNotes}"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                            <Label Text="Nema beleški"
                                   FontSize="14"
                                   FontAttributes="Italic"
                                   TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"
                                   IsVisible="{Binding EditorNotes.Length, Converter={StaticResource ZeroIntToBoolConverter}}" />
                        </VerticalStackLayout>

                        <!-- Notes - Edit Mode -->
                        <VerticalStackLayout Spacing="4" IsVisible="{Binding IsViewMode, Converter={StaticResource InvertedBoolConverter}}">
                            <Label Text="Beleške" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" FontAttributes="Bold" />
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardSecondaryLight}, Dark={StaticResource CardSecondaryDark}}" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="12" HeightRequest="80">
                                <Editor Text="{Binding EditorNotes}"
                                        Placeholder="Unesite beleške..."
                                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"
                                        TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                        BackgroundColor="Transparent" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Location - View Mode -->
                        <VerticalStackLayout Spacing="4" IsVisible="{Binding IsViewMode}">
                            <Label Text="Lokacija" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" FontSize="12" />
                            <Label Text="{Binding EditorLocationName}"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                   IsVisible="{Binding EditorHasLocation}" />
                            <Label Text="Lokacija nije sačuvana"
                                   FontSize="14"
                                   FontAttributes="Italic"
                                   TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"
                                   IsVisible="{Binding EditorHasLocation, Converter={StaticResource InvertedBoolConverter}}" />
                        </VerticalStackLayout>

                        <!-- Location - Edit Mode -->
                        <VerticalStackLayout Spacing="4" IsVisible="{Binding IsViewMode, Converter={StaticResource InvertedBoolConverter}}">
                            <Label Text="Lokacija" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" FontAttributes="Bold" />
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardSecondaryLight}, Dark={StaticResource CardSecondaryDark}}" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="12">
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                    <Label Text="{Binding EditorLocationName}"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                           VerticalOptions="Center"
                                           IsVisible="{Binding EditorHasLocation}" />
                                    <Label Text="Lokacija nije postavljena"
                                           TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"
                                           VerticalOptions="Center"
                                           IsVisible="{Binding EditorHasLocation, Converter={StaticResource InvertedBoolConverter}}" />
                                    <Button Grid.Column="1"
                                            Text="📍"
                                            Command="{Binding GetCurrentLocationCommand}"
                                            BackgroundColor="#1B5E20"
                                            TextColor="White"
                                            WidthRequest="44"
                                            HeightRequest="44"
                                            CornerRadius="8"
                                            IsVisible="{Binding IsGettingLocation, Converter={StaticResource InvertedBoolConverter}}" />
                                    <ActivityIndicator Grid.Column="1"
                                                       IsRunning="{Binding IsGettingLocation}"
                                                       IsVisible="{Binding IsGettingLocation}"
                                                       Color="#1B5E20"
                                                       WidthRequest="44"
                                                       HeightRequest="44" />
                                    <Button Grid.Column="2"
                                            Text="✕"
                                            Command="{Binding ClearEditorLocationCommand}"
                                            BackgroundColor="Transparent"
                                            TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"
                                            WidthRequest="40"
                                            HeightRequest="40"
                                            IsVisible="{Binding EditorHasLocation}" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Add fish - only in Edit Mode -->
                        <VerticalStackLayout Spacing="8" IsVisible="{Binding IsViewMode, Converter={StaticResource InvertedBoolConverter}}">
                            <Label Text="Dodaj ulov" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" FontAttributes="Bold" />
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardSecondaryLight}, Dark={StaticResource CardSecondaryDark}}" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="12">
                                <VerticalStackLayout Spacing="8">
                                    <Picker ItemsSource="{Binding FilteredFishTypes}"
                                            SelectedItem="{Binding SelectedFishType}"
                                            Title="Izaberi vrstu ribe"
                                            TitleColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"
                                            TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                        <Entry Text="{Binding FishQuantity}"
                                               Placeholder="Količina"
                                               PlaceholderColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"
                                               TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                               Keyboard="Numeric"
                                               IsVisible="{Binding UseQuantity}" />
                                        <Entry Text="{Binding FishWeight}"
                                               Placeholder="Težina (kg)"
                                               PlaceholderColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"
                                               TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                               Keyboard="Numeric"
                                               IsVisible="{Binding UseQuantity, Converter={StaticResource InvertedBoolConverter}}" />

                                        <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                                            <RadioButton Content="Kom" IsChecked="{Binding UseQuantity}" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                                            <RadioButton Content="Kg" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                                        </HorizontalStackLayout>

                                        <Button Grid.Column="2"
                                                Text="+"
                                                Command="{Binding AddFishToListCommand}"
                                                BackgroundColor="#1B5E20"
                                                TextColor="White"
                                                WidthRequest="44"
                                                HeightRequest="44"
                                                CornerRadius="8" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Fish list - View Mode (read only) -->
                        <VerticalStackLayout Spacing="8" IsVisible="{Binding IsViewMode}">
                            <Label Text="Ulov" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" FontSize="12" />
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardSecondaryLight}, Dark={StaticResource CardSecondaryDark}}" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="8" MinimumHeightRequest="60">
                                <CollectionView ItemsSource="{Binding EditorCaughtFish}" SelectionMode="None">
                                    <CollectionView.EmptyView>
                                        <Label Text="Bez ulova"
                                               TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"
                                               FontAttributes="Italic"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </CollectionView.EmptyView>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:CaughtFish">
                                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource ListItemLight}, Dark={StaticResource ListItemDark}}"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 6"
                                                    Padding="12,8"
                                                    Margin="0,0,0,4">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <Label Text="{Binding FishName}" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" VerticalOptions="Center" />
                                                    <Label Grid.Column="1" Text="{Binding DisplayQuantity}" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" VerticalOptions="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Fish list - Edit Mode -->
                        <VerticalStackLayout Spacing="8" IsVisible="{Binding IsViewMode, Converter={StaticResource InvertedBoolConverter}}">
                            <Label Text="Lista ulova" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" FontAttributes="Bold" />
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardSecondaryLight}, Dark={StaticResource CardSecondaryDark}}" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="8" MinimumHeightRequest="100">
                                <CollectionView ItemsSource="{Binding EditorCaughtFish}" SelectionMode="None">
                                    <CollectionView.EmptyView>
                                        <Label Text="Još niste dodali ulov"
                                               TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </CollectionView.EmptyView>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:CaughtFish">
                                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource ListItemLight}, Dark={StaticResource ListItemDark}}"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 6"
                                                    Padding="12,8"
                                                    Margin="0,0,0,4">
                                                <Grid ColumnDefinitions="*,Auto,Auto">
                                                    <Label Text="{Binding FishName}" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" VerticalOptions="Center" />
                                                    <Label Grid.Column="1" Text="{Binding DisplayQuantity}" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" VerticalOptions="Center" Margin="0,0,12,0" />
                                                    <Button Grid.Column="2"
                                                            Text="🗑️"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DiaryViewModel}}, Path=RemoveFishFromListCommand}"
                                                            CommandParameter="{Binding}"
                                                            BackgroundColor="Transparent"
                                                            WidthRequest="36"
                                                            HeightRequest="36" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Slike - View Mode (read only) -->
                        <VerticalStackLayout Spacing="8" IsVisible="{Binding IsViewMode}">
                            <Label Text="Slike" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" FontSize="12" />

                            <CollectionView ItemsSource="{Binding EditorImages}"
                                            HeightRequest="100"
                                            SelectionMode="None">
                                <CollectionView.EmptyView>
                                    <Label Text="Nema slika"
                                           TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"
                                           FontSize="12"
                                           FontAttributes="Italic"
                                           HorizontalOptions="Center" />
                                </CollectionView.EmptyView>
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Border StrokeThickness="0"
                                                StrokeShape="RoundRectangle 8"
                                                WidthRequest="90"
                                                HeightRequest="90">
                                            <Image Source="{Binding .}"
                                                   Aspect="AspectFill"
                                                   WidthRequest="90"
                                                   HeightRequest="90">
                                                <Image.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DiaryViewModel}}, Path=PreviewImageCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Image.GestureRecognizers>
                                            </Image>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>

                        <!-- Slike - Edit Mode -->
                        <VerticalStackLayout Spacing="8" IsVisible="{Binding IsViewMode, Converter={StaticResource InvertedBoolConverter}}">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Slike"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                       FontSize="14"
                                       VerticalOptions="Center" />
                                <Button Grid.Column="1"
                                        Text="+ Dodaj"
                                        Command="{Binding AddImageCommand}"
                                        BackgroundColor="#1B5E20"
                                        TextColor="White"
                                        CornerRadius="8"
                                        HeightRequest="32"
                                        Padding="12,0"
                                        FontSize="12" />
                            </Grid>

                            <CollectionView ItemsSource="{Binding EditorImages}"
                                            HeightRequest="100"
                                            SelectionMode="None">
                                <CollectionView.EmptyView>
                                    <Label Text="Nema slika"
                                           TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"
                                           FontSize="12"
                                           HorizontalOptions="Center" />
                                </CollectionView.EmptyView>
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Border StrokeThickness="0"
                                                StrokeShape="RoundRectangle 8"
                                                WidthRequest="90"
                                                HeightRequest="90">
                                            <Grid>
                                                <Image Source="{Binding .}"
                                                       Aspect="AspectFill"
                                                       WidthRequest="90"
                                                       HeightRequest="90">
                                                    <Image.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DiaryViewModel}}, Path=PreviewImageCommand}"
                                                            CommandParameter="{Binding .}" />
                                                    </Image.GestureRecognizers>
                                                </Image>
                                                <Button Text="✕"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DiaryViewModel}}, Path=RemoveImageCommand}"
                                                        CommandParameter="{Binding .}"
                                                        BackgroundColor="#80000000"
                                                        TextColor="White"
                                                        WidthRequest="24"
                                                        HeightRequest="24"
                                                        CornerRadius="12"
                                                        Padding="0"
                                                        FontSize="10"
                                                        HorizontalOptions="End"
                                                        VerticalOptions="Start"
                                                        Margin="4" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>

                        <!-- Buttons - View Mode -->
                        <HorizontalStackLayout HorizontalOptions="End" Spacing="8" IsVisible="{Binding IsViewMode}">
                            <Button Text="Zatvori"
                                    Command="{Binding CancelEditorCommand}"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource CardSecondaryLight}, Dark={StaticResource CardSecondaryDark}}"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                    CornerRadius="8"
                                    Padding="20,12" />
                        </HorizontalStackLayout>

                        <!-- Buttons - Edit Mode -->
                        <HorizontalStackLayout HorizontalOptions="End" Spacing="8" IsVisible="{Binding IsViewMode, Converter={StaticResource InvertedBoolConverter}}">
                            <Button Text="Otkaži"
                                    Command="{Binding CancelEditorCommand}"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource CardSecondaryLight}, Dark={StaticResource CardSecondaryDark}}"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                    CornerRadius="8"
                                    Padding="20,12" />
                            <Button Text="Sačuvaj"
                                    Command="{Binding SaveEntryCommand}"
                                    BackgroundColor="#1B5E20"
                                    TextColor="White"
                                    CornerRadius="8"
                                    Padding="20,12">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding EditorTitle.Length}" Value="0">
                                        <Setter Property="Opacity" Value="0.5" />
                                        <Setter Property="IsEnabled" Value="False" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
